{
  "name": "eat-ticker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/set-db-provider.mjs && prisma generate && prisma db push --skip-generate && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "node scripts/set-db-provider.mjs && prisma generate",
    "db:push": "node scripts/set-db-provider.mjs && prisma db push",
    "db:seed": "node prisma/seed.mjs",
    "db:reset": "node scripts/set-db-provider.mjs && prisma db push --force-reset --skip-generate && node prisma/seed.mjs",
    "db:studio": "node scripts/set-db-provider.mjs && prisma studio"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^6.19.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.22.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "recharts": "^3.9.1",
    "server-only": "^0.0.1",
    "shadcn": "^4.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "sharp": "^0.35.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
